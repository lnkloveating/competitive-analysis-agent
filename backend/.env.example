# Local backend environment template.
# Copy this file to backend/.env and fill values as needed.

ARK_API_KEY=
ARK_EP=
ARK_MODEL=doubao-seed-2-0-lite

# Set these to 0 for mock/local runs. Set to 1 after ARK_API_KEY and ARK_EP are valid.
RESEARCH_AGENT_USE_LLM=0
EVIDENCE_AGENT_USE_LLM=0
PRODUCT_AGENT_USE_LLM=0
BUSINESS_AGENT_USE_LLM=0
RISK_AGENT_USE_LLM=0
QUALITY_AGENT_USE_LLM=0
STRATEGY_AGENT_USE_LLM=0

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=competitive-analysis-agent

LOG_LEVEL=INFO
