# Local backend environment template.
# Copy this file to backend/.env and fill values as needed.

ARK_API_KEY=
ARK_EP=
ARK_MODEL=doubao-seed-2-0-lite

# Set these to 0 for mock/local runs. Set to 1 after ARK_API_KEY and ARK_EP are valid.
RESEARCH_AGENT_USE_LLM=0
EVIDENCE_AGENT_USE_LLM=0
QUALITY_AGENT_USE_LLM=0

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=competitive-analysis-agent

LOG_LEVEL=INFO

# ===== Search MCP（未知产品搜索 / 官方候选发现）=====
# 默认关闭，避免本地测试消耗额度。启用时复制到 backend/.env：
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=tvly-...
SEARCH_PROVIDER=disabled
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=6
SEARCH_COUNTRY=united states
SEARCH_CACHE_TTL_SECONDS=604800

# ===== Official Spec MCP: official page + LLM structured extraction =====
# Default off for local tests. Set to 1 after ARK_API_KEY and ARK_EP are valid.
# OFFICIAL_SPEC_API_KEY can be used separately; empty value reuses ARK_API_KEY.
OFFICIAL_SPEC_USE_LLM=0
OFFICIAL_SPEC_API_KEY=
OFFICIAL_SPEC_MODEL=
OFFICIAL_SPEC_MAX_CHARS=30000
OFFICIAL_SPEC_TIMEOUT_SECONDS=12
OFFICIAL_SPEC_MAX_PRODUCTS=2

# ===== 认证 / 数据库（登录功能）=====
# 配置以下 MySQL 变量后将使用 MySQL；留空则自动回退本地 SQLite（backend/auth/auth.db），
# 便于零配置演示。两种方式都使用 bcrypt 哈希与 JWT。
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=competitive_analysis

# JWT 配置（JWT_SECRET 建议至少 32 字符的随机字符串）
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRE_MINUTES=1440

# 默认管理员（首次初始化时写入，可覆盖）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123456
